def analisar_duplicidades():
    dados_sistema["avisos"] = []
    por_semana = {}  
    for item in dados_sistema["escala_dados"]:  
        try:  
            data_obj = datetime.strptime(item["data"], "%d/%m/%Y").date()  
            ano_iso, num_semana, _ = data_obj.isocalendar()  
            chave_semana = f"{ano_iso}-W{num_semana:02d}"  
            if chave_semana not in por_semana: por_semana[chave_semana] = []  
            por_semana[chave_semana].append(item)  
        except Exception: 
            pass

    categorias = [
        {"chave": "ministros", "singular": "Ministro(a)"},
        {"chave": "acolitos", "singular": "Acólito"},
        {"chave": "coroinhas", "singular": "Coroinha"},
        {"chave": "canto", "singular": "Integrante do Canto"},
        {"chave": "liturgia", "singular": "Equipe de Liturgia"}
    ]

    for chave_semana, celebracoes in por_semana.items():  
        for i, cel_a in enumerate(celebracoes):  
            for j, cel_b in enumerate(celebracoes):  
                if i >= j: continue  
                for cat in categorias:
                    comuns = set(cel_a[cat["chave"]]).intersection(set(cel_b[cat["chave"]]))  
                    for pessoa in comuns:  
                        if pessoa.strip():  
                            msg = f"O(A) {cat['singular']} <b>{pessoa}</b> está escalado(a) mais de uma vez na mesma semana:<br/>• {cel_a['data']} em {cel_a['igreja']}<br/>• {cel_b['data']} em {cel_b['igreja']}"  
