def carregar_lista(tipo, rotulo_padrao, extra_vagas=10):
    caminho = ARQUIVOS[tipo]
    nomes = []
    
    # 1. Carrega do arquivo se existir
    if os.path.exists(caminho):
        try:
            with open(caminho, "r", encoding="utf-8") as f:
                nomes = [linha.strip() for linha in f.readlines() if linha.strip()]
        except Exception:
            nomes = []

    # 2. Se o arquivo estava vazio, usa os dados padrão fornecidos
    if not nomes:
        nomes = LISTAS_INICIAIS.get(tipo, [])

    nomes.sort(key=str.lower)
    
    # 3. Adiciona as 10 vagas extras/substitutas configuráveis
    total_desejado = len(nomes) + extra_vagas
    contador_padrao = 1
    
    while len(nomes) < total_desejado:
        novo_nome = f"{rotulo_padrao} {contador_padrao:02d}"
        if novo_nome not in nomes:
            nomes.append(novo_nome)
        contador_padrao += 1
        
    return nomes

def salvar_lista_no_disco(tipo, lista_nomes):
    try:
        with open(ARQUIVOS[tipo], "w", encoding="utf-8") as f:
            for nome in lista_nomes:
                f.write(nome + "\n")
    except Exception as e:
        print(f"Erro ao salvar arquivo {tipo}: {e}")

